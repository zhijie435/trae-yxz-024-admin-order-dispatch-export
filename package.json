{
  "name": "order-admin-platform",
  "version": "1.0.0",
  "description": "全平台订单管理后台 - 列表、筛选、指派、导出",
  "scripts": {
    "dev:server": "ts-node-dev --respawn --transpile-only api/server.ts",
    "dev:client": "cd client && npm run dev",
    "build:server": "tsc -p tsconfig.json",
    "build:client": "cd client && npm run build",
    "start": "node dist/api/server.js",
    "install:all": "npm install && cd client && npm install",
    "test": "jest",
    "test:ci": "jest --ci --coverage"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
